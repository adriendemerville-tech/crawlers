{
  "manifest_version": 3,
  "name": "Crawlers — SEO & GEO Audit",
  "version": "1.0.0",
  "description": "Auditez n'importe quelle page web et alimentez votre Workbench Crawlers en un clic.",
  "permissions": ["activeTab", "storage", "tabs", "sidePanel", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Crawlers — Auditer cette page",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
