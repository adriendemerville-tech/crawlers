{
  "name": "@crawlers/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the Crawlers API — SEO, GEO & AI visibility audits.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["crawlers", "seo", "geo", "ai-visibility", "serp", "audit", "api", "sdk"],
  "author": "Crawlers.fr",
  "license": "MIT",
  "homepage": "https://crawlers.fr/developers",
  "repository": {
    "type": "git",
    "url": "https://github.com/crawlers-fr/sdk-js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
