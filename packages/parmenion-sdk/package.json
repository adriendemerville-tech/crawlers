{
  "name": "@parmenion/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the Parménion API — pull model for content tasks (Autopilote).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run"
  },
  "keywords": ["parmenion", "autopilote", "content", "cms", "seo"],
  "author": "Crawlers.fr",
  "license": "MIT",
  "homepage": "https://crawlers.fr/developers",
  "engines": { "node": ">=18" },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
